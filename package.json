{
  "name": "cuttlefish",
  "private": true,
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-spawn-helper.mjs",
    "build": "turbo run build --filter=@cuttlefish/web && turbo run build --filter=cuttlefish-cli && node -e \"const fs=require('fs');fs.rmSync('packages/cuttlefish/dist/web',{recursive:true,force:true});fs.cpSync('packages/web/out','packages/cuttlefish/dist/web',{recursive:true})\"",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo run test --concurrency=1",
    "coverage": "turbo run coverage",
    "test:e2e": "playwright test",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('.turbo',{recursive:true,force:true});fs.rmSync('node_modules/.cache',{recursive:true,force:true})\" && turbo clean",
    "cuttlefish": "node scripts/run-cuttlefish-cli.mjs",
    "setup": "pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js setup",
    "setup:force": "pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js setup --force",
    "start": "pnpm clean && pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js start",
    "stop": "node scripts/run-cuttlefish-cli.mjs stop",
    "nuke": "node scripts/run-cuttlefish-cli.mjs nuke",
    "status": "node scripts/run-cuttlefish-cli.mjs status",
    "validate:rdc-r03": "node scripts/validate-rdc-r03.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "yaml": "^2.9.0"
  }
}
