{
  "name": "cuttlefish",
  "private": true,
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-spawn-helper.mjs",
    "build": "turbo run build --filter=@cuttlefish/web && turbo run build --filter=cuttlefish-cli && rm -rf packages/cuttlefish/dist/web && cp -r packages/web/out packages/cuttlefish/dist/web",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo run test --concurrency=1",
    "coverage": "turbo run coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf .turbo node_modules/.cache && turbo clean",
    "cuttlefish": "node scripts/run-cuttlefish-cli.mjs",
    "setup": "pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js setup",
    "setup:force": "pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js setup --force",
    "start": "pnpm clean && pnpm build && node packages/cuttlefish/dist/bin/cuttlefish.js start",
    "stop": "node scripts/run-cuttlefish-cli.mjs stop",
    "nuke": "node scripts/run-cuttlefish-cli.mjs nuke",
    "status": "node scripts/run-cuttlefish-cli.mjs status"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "turbo": "^2.10.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "classic-level": "^2.0.0"
  }
}
