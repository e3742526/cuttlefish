{
  "name": "cuttlefish-cli",
  "version": "0.23.3",
  "description": "Cuttlefish AI gateway daemon orchestrating professional AI coding CLIs",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "bin": {
    "cuttlefish": "./dist/bin/cuttlefish.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/",
    "template/",
    "assets/"
  ],
  "bundledDependencies": [
    "@cuttlefish/contracts"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node scripts/build-postprocess.mjs",
    "dev": "tsc && (tsc --watch &) && node --watch-path=dist dist/bin/cuttlefish.js start",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "verify:package": "node scripts/verify-package.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@cuttlefish/contracts": "0.1.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "@slack/bolt": "^4.3.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.6.2",
    "busboy": "^1.6.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "imapflow": "^1.4.7",
    "js-yaml": "^4.1.0",
    "mailparser": "^3.9.14",
    "node-cron": "^4.6.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "twilio": "6.0.2",
    "uuid": "^14.0.1",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/busboy": "^1.5.4",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "ai-agents",
    "ai-gateway",
    "agent-orchestration",
    "claude",
    "claude-code",
    "codex",
    "grok",
    "antigravity",
    "llm",
    "anthropic",
    "coding-agent",
    "cli",
    "daemon",
    "mcp",
    "cron",
    "slack"
  ],
  "homepage": "https://github.com/cephalopod-ai/cuttlefish#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cephalopod-ai/cuttlefish.git",
    "directory": "packages/cuttlefish"
  },
  "bugs": {
    "url": "https://github.com/cephalopod-ai/cuttlefish/issues"
  }
}
