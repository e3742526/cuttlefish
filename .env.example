# Qdrant configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# API key sent by the client AND enforced by the server (docker-compose wires this
# into QDRANT__SERVICE__API_KEY). Leave empty only for local, loopback-bound dev.
# Set a strong value before exposing Qdrant beyond this host, and front it with TLS.
QDRANT_API_KEY=

# Optional: full URL override (e.g. an https endpoint behind an authenticating
# proxy). When set it takes precedence over QDRANT_HOST/QDRANT_PORT.
# QDRANT_URL=https://qdrant.internal.example:6333
